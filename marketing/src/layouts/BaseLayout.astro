---
import "../styles/global.css";
// B-NEW-10 / TONGUE-10 — every marketing page must mount the cookie
// banner so EU visitors are not tracked before consent. Banner ships
// hidden if the user already consented (record rehydrated from the
// shared `.motionmax.io` cookie written by the React app).
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  darkMode?: boolean;
  noIndex?: boolean;
  breadcrumbs?: { name: string; item: string }[];
  /**
   * B-NEW-13 (Comply L-B-02): when set, emits
   * <meta name="document-version" content="..."/>
   * so the binding version of legal pages is machine-readable.
   */
  documentVersion?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://motionmax.io/og-image.png?v=20260129",
  darkMode = false,
  noIndex = false,
  breadcrumbs,
  documentVersion,
} = Astro.props;

// B-NEW-10 — GA measurement ID is exposed to the client via a meta tag
// rather than baked into the bundle, so rotating the ID on Vercel does
// NOT require a marketing rebuild. Only `PUBLIC_*` env vars are visible
// at Astro render time. If unset (or set to the placeholder from
// .env.example) the analytics module short-circuits and never loads
// gtag.
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";

const structuredData = breadcrumbs
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: b.item,
      })),
    })
  : null;
---

<!doctype html>
<html lang="en" class={darkMode ? "dark" : ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="MotionMax" />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    }
    <link rel="canonical" href={canonical} />
    {documentVersion && <meta name="document-version" content={documentVersion} />}

    {/*
      B-NEW-10 — GA ID for marketingAnalytics.js to read at runtime. The
      analytics module only fires gtag if the user has granted analytics
      consent AND this meta is present with a non-placeholder G-XXXXXX
      value. No script is loaded otherwise.
    */}
    {gaMeasurementId && <meta name="motionmax-ga-id" content={gaMeasurementId} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="MotionMax" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@motionmaxio" />

    <link rel="icon" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0F1112" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700&display=swap"
    />

    {structuredData && <script type="application/ld+json" set:html={structuredData} />}
  </head>
  <body>
    <slot />
    {/*
      B-NEW-10 — every marketing page renders the consent banner. It
      ships hidden and reveals itself on DOMContentLoaded only when the
      user has not answered under the current policy version (or
      revoked via the footer link). The banner script also kicks the
      analytics loader, which is gated on per-category consent.
    */}
    <CookieBanner />
    {/*
      B-NEW-7 (Lens B) — UTM capture must run on every marketing page so
      first-touch attribution survives the marketing→app handoff. Loaded
      AFTER <CookieBanner /> on the page so the banner's import of
      cookieConsent.js has already been evaluated; the capture itself is
      idempotent and re-runs on every consent-changed event.

      Mounted via a same-origin <script src="...">-style import (Astro
      emits this as a hashed /_astro/*.js) rather than is:inline because
      the marketing CSP is `script-src 'self'` with no nonce — any inline
      block would be rejected. Same constraint as cookieBanner.js.
    */}
    <script>
      import { initUtmCapture } from "../scripts/utmCapture.js";
      initUtmCapture();
    </script>
  </body>
</html>
