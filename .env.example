# ============================================================
# MotionMax Environment Variables — copy to .env and fill in
# NEVER commit .env — it is already in .gitignore
# ============================================================

# Supabase (client-side — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Optional: override the app's base URL (used for share links in development)
# VITE_APP_URL=http://localhost:8080

# Worker environment (server-side only — NEVER expose in browser)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# OPENROUTER_API_KEY=your-openrouter-key
# HYPEREAL_API_KEY=your-hypereal-key
# REPLICATE_API_KEY=your-replicate-key
# ELEVENLABS_API_KEY=your-elevenlabs-key
# FISH_AUDIO_API_KEY=your-fish-audio-key
# LEMONFOX_API_KEY=your-lemonfox-key
# GOOGLE_TTS_API_KEY=your-google-tts-key
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google Analytics 4 (required in production — analytics silently disabled if unset)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase edge function secrets (set via `supabase secrets set` — not in .env)
# STRIPE_SECRET_KEY=sk_live_...
# SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
# ALLOWED_ORIGIN=https://motionmax.io

# Sentry error tracking (strongly recommended for production)
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Sentry source map upload (CI/CD only — not needed locally)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=motionmax
# SENTRY_PROJECT=motionmax-frontend

# Worker health endpoint auth (optional — protects /metrics endpoint)
# HEALTH_AUTH_TOKEN=your-secret-token
