# IMPORTANT: Rotate SUPABASE_SERVICE_ROLE_KEY in Supabase dashboard immediately - this key was exposed in git history

# ============================================================
# MotionMax Worker Environment Variables
# Copy to .env and fill in values
# ============================================================

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Generation (REQUIRED - at least one)
# HYPEREAL_API_KEY: video / image-edit / lipsync / ASR / music account.
# HYPEREALIMAGE_API_KEY: image-gen-only account (gpt-image-2 + Gemini
#   fallback). When set, overrides HYPEREAL_API_KEY for image gen so
#   image-gen spend is tracked separately. If unset, image gen falls
#   back to HYPEREAL_API_KEY (single-account deployments still work).
# OPENROUTER_API_KEY: middle fallback (openai/gpt-5.4-image-2) — fires
#   only when Hypereal gpt-image-2 is down. Pricier per image (~$0.22).
HYPEREAL_API_KEY=your-hypereal-key
HYPEREALIMAGE_API_KEY=your-hypereal-image-key
OPENROUTER_API_KEY=your-openrouter-key
REPLICATE_API_KEY=your-replicate-key

# Text-to-Speech (REQUIRED - at least one)
ELEVENLABS_API_KEY=your-elevenlabs-key
FISH_AUDIO_API_KEY=your-fish-audio-key
LEMONFOX_API_KEY=your-lemonfox-key
GOOGLE_TTS_API_KEY=your-google-tts-key
# GOOGLE_TTS_API_KEY_2=your-google-tts-key-2
# GOOGLE_TTS_API_KEY_3=your-google-tts-key-3

# Worker Health (OPTIONAL)
# HEALTH_AUTH_TOKEN=your-secret-token
# PORT=10000

# Export Configuration (OPTIONAL - defaults shown)
# EXPORT_BATCH_SIZE=3
# EXPORT_SCENE_TIMEOUT_MS=300000
# EXPORT_KEN_BURNS=true
# EXPORT_CROSSFADE_DURATION=0.5
# EXPORT_AI_VIDEO=false
