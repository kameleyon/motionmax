#   export TF_VAR_supabase_publishable_key_production=...
#   export TF_VAR_supabase_url_preview=https://<staging-ref>.supabase.co
#   export TF_VAR_supabase_publishable_key_preview=...
#   export TF_VAR_vercel_api_token=...
