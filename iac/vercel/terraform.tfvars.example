# Copy to terraform.tfvars (gitignored). Sensitive values should be
# exported as TF_VAR_* env vars rather than written to this file.

vercel_team_id = "team_REPLACE_ME"

# Optional overrides — defaults usually fine.
# github_repo       = "kameleyon/motionmax"
# production_branch = "main"

# Supabase wiring — set via env vars, not here:
