---
import LegalLayout from "../layouts/LegalLayout.astro";

/**
 * Do Not Sell or Share My Personal Information — CCPA / CPRA landing
 * (Wave E-Legal Part G). Mirrors src/pages/DoNotSellMyInfo.tsx so the
 * disclosure is reachable from both the marketing site and the in-app
 * footer without the user having to be authenticated.
 */
---

<LegalLayout
  title="Do Not Sell or Share My Personal Information — MotionMax"
  description="MotionMax does not sell or share personal information. Submit a CCPA / CPRA request and learn how we honour the Global Privacy Control signal."
  canonical="https://motionmax.io/do-not-sell"
>
  <h1 class="text-3xl font-bold tracking-tight text-foreground mb-2">
    Do Not Sell or Share My Personal Information
  </h1>
  <p class="text-sm text-muted-foreground mb-10">
    California Consumer Privacy Act (CCPA) / California Privacy Rights Act (CPRA)
  </p>

  <div class="space-y-8 text-muted-foreground">

    <section class="space-y-3 rounded-md border border-[#14C8CC]/30 bg-[#14C8CC]/5 p-4">
      <h2 class="text-lg font-semibold text-foreground m-0">Our position</h2>
      <p class="m-0">
        <strong class="text-foreground">MotionMax does not sell or share personal information.</strong>
        We do not engage in "sale" of personal information as defined by Cal. Civ. Code §1798.140(ad),
        and we do not engage in "sharing" for cross-context behavioural advertising as defined by
        §1798.140(ah). We do not exchange personal information for monetary or other valuable
        consideration. If our practices ever change, we will update this page and the Privacy Policy,
        and we will provide a working opt-out mechanism on this page before any sale or sharing begins.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-foreground">What this means in practice</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>We do not run third-party advertising pixels for retargeting.</li>
        <li>We do not sell or license your account data, generated content, voice samples, or usage history to data brokers, advertising networks, or analytics resellers.</li>
        <li>We disclose personal information only to the subprocessors listed in our <a href="/privacy#5" class="text-primary hover:underline">Privacy Policy §5</a> strictly to deliver the Service you requested.</li>
        <li>The Analytics cookies we use (Google Analytics 4, Sentry session replay) are consent-gated and configured for first-party measurement; they are not used for cross-context behavioural advertising.</li>
      </ul>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-foreground">Global Privacy Control (GPC)</h2>
      <p>
        We honour the Global Privacy Control signal. If your browser sends
        <span class="font-mono">Sec-GPC: 1</span> or sets
        <span class="font-mono">navigator.globalPrivacyControl = true</span>, we automatically
        treat it as a valid opt-out of the Analytics and Marketing cookie categories &mdash; without
        requiring a separate request. This is consistent with the California Attorney General's
        guidance following the 2022 Sephora settlement.
      </p>
      <p>
        You can read more about how GPC interacts with our consent banner on the
        <a href="/cookies#6" class="text-primary hover:underline">Cookie Policy §6</a>.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-foreground">Submit a CCPA request</h2>
      <p>
        California residents may also submit any CCPA / CPRA request &mdash; to know, to delete, to
        correct, to limit use of Sensitive Personal Information (including voice biometric data),
        or to opt out &mdash; via the contact path below. An authorised agent may submit on your behalf
        with written authorisation; we may verify your identity before disclosing personal information.
      </p>
      <p>
        Email: <a href="mailto:privacy@motionmax.io" class="text-primary hover:underline">privacy@motionmax.io</a>
      </p>
      <p>
        We respond to verified requests within <strong class="text-foreground">30 days</strong>,
        with a possible extension of up to 60 additional days for complex requests (we will notify
        you within the initial 30-day window).
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-foreground">Right to Non-Discrimination</h2>
      <p>
        We will not deny goods or services, charge different prices, or provide a different level
        of quality because you exercised any CCPA / CPRA right.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-foreground">More information</h2>
      <p>
        For the full categories of personal information we collect, business purposes, retention
        periods, and your other rights, see the California section of our
        <a href="/privacy#12" class="text-primary hover:underline">Privacy Policy §12</a>.
      </p>
    </section>

  </div>
</LegalLayout>
