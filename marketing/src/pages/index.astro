---
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  {
    icon: "🎬",
    title: "Cinematic AI Videos",
    description: "15–36 scene videos with AI image-to-video, seamless scene transitions, and camera motion direction.",
  },
  {
    icon: "🎙️",
    title: "AI Voiceover & Cloning",
    description: "9+ AI voices with emotion-aware style. Clone your own voice for consistent narration across projects.",
  },
  {
    icon: "✨",
    title: "AI Research & Script",
    description: "Claude AI researches your topic for accuracy — verified facts, real appearances, cultural context — then writes the script.",
  },
  {
    icon: "💬",
    title: "25+ Caption Styles",
    description: "From Classic to Karaoke word-by-word. Captions burned directly into the video. Pick your style, change it anytime.",
  },
  {
    icon: "🌍",
    title: "11 Languages",
    description: "English, French, Spanish, Portuguese, German, Italian, Russian, Chinese, Japanese, Korean, Haitian Creole.",
  },
  {
    icon: "✏️",
    title: "Scene-by-Scene Editing",
    description: "Edit any image with AI text instructions. Regenerate audio or video per scene. Affected transitions auto-update.",
  },
];

const faqs = [
  {
    q: "What is MotionMax?",
    a: "MotionMax is an AI-powered content creation platform that turns text, documents, and ideas into professional-quality narrated videos — complete with AI visuals, voiceovers, and multiple art styles.",
  },
  {
    q: "Do I need video editing experience?",
    a: "No. MotionMax handles scene-by-scene planning, image generation, and audio narration automatically. Just paste your text or describe your topic and the AI does the rest.",
  },
  {
    q: "Is there a free plan?",
    a: "Yes! The free plan includes monthly credits so you can create short videos and explore all core features — no credit card required.",
  },
  {
    q: "What video formats and resolutions are supported?",
    a: "MotionMax supports 16:9 (landscape), 9:16 (portrait / Reels), and 1:1 (square) formats. Paid plans unlock 1080p and 4K exports.",
  },
  {
    q: "Can I use my own voice?",
    a: "Absolutely. Creator and Studio plans include voice cloning — upload a short sample and generate narrations in your own voice.",
  },
  {
    q: "How do credits work?",
    a: "Each generation consumes credits based on complexity and length. Credits reset monthly. You can also purchase credit packs at any time.",
  },
  {
    q: "Can I cancel my subscription?",
    a: "Yes, you can cancel anytime from your account Settings. You'll retain access to paid features until the end of your current billing cycle.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "MotionMax",
  description: "AI video generator that creates cinematic videos, explainers, visual stories, and infographics from text.",
  url: "https://motionmax.io",
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "AI Cinematic Video Generation",
    "AI Explainer Video Creation",
    "25+ Caption Styles",
    "11 Languages",
    "Voice Cloning",
    "Scene-by-Scene Editing",
    "AI Scriptwriting",
    "Image-to-Video",
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout
  title="MotionMax — AI Video Generator | Turn Text into Cinematic Videos"
  description="Create stunning AI-generated cinematic videos, explainers, and visual stories from any text. AI scriptwriting, voiceover, image-to-video with 25+ caption styles. Multi-language. Start free."
  canonical="https://motionmax.io"
  darkMode={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- ── Nav ─────────────────────────────────────────────── -->
  <nav class="fixed top-0 inset-x-0 z-50 border-b border-white/10 bg-background/80 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
      <a href="/" class="flex items-center gap-2" aria-label="MotionMax home">
        <img src="/momaxlogo.webp" alt="MotionMax" class="h-8 w-auto" />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6 text-sm text-muted-foreground">
        <a href="#features" class="hover:text-foreground transition-colors">Features</a>
        <a href="#pricing" class="hover:text-foreground transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-foreground transition-colors">FAQ</a>
        <a href="/auth" class="text-foreground hover:text-foreground transition-colors">Sign in</a>
        <a
          href="/auth"
          class="rounded-xl bg-primary px-5 py-2 font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
        >
          Start Free
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground hover:text-foreground"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg id="icon-x" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-background px-4 pb-4 pt-2">
      <div class="flex flex-col gap-3 text-sm">
        <a href="#features" class="py-2 text-muted-foreground hover:text-foreground transition-colors">Features</a>
        <a href="#pricing" class="py-2 text-muted-foreground hover:text-foreground transition-colors">Pricing</a>
        <a href="#faq" class="py-2 text-muted-foreground hover:text-foreground transition-colors">FAQ</a>
        <a href="/auth" class="py-2 text-muted-foreground hover:text-foreground transition-colors">Sign in</a>
        <a href="/auth" class="rounded-xl bg-primary px-5 py-2.5 text-center font-semibold text-primary-foreground">
          Start Free
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="hero relative min-h-screen flex items-center justify-center pt-16">
      <div class="hero-bg"></div>
      <div class="hero-content mx-auto max-w-3xl px-4 sm:px-6 text-center">
        <!-- Hero image (replaces logo + brand name) -->
        <div class="mb-7 flex justify-center">
          <img src="/motion.png" alt="MotionMax" class="h-32 sm:h-40 md:h-48 w-auto" />
        </div>

        <!-- Descriptor -->
        <p class="mb-7 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary/70">
          AI Video Generator
        </p>

        <h1 class="text-base sm:text-3xl md:text-4xl font-semibold tracking-tight text-white leading-[1.3]">
          Cinematic visuals. Natural voiceover.<br />
          Seamless transitions. <span class="text-primary">From one idea.</span>
        </h1>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 px-4">
          <a
            href="/auth"
            class="w-full sm:w-auto rounded-xl bg-primary px-7 py-3.5 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity shadow-lg shadow-primary/30 text-center"
          >
            Try for Free
          </a>
          <button
            id="demo-btn"
            class="w-full sm:w-auto flex items-center justify-center gap-2 rounded-xl border border-white/20 px-7 py-3.5 text-sm font-semibold text-white/80 hover:bg-white/10 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Watch Demo
          </button>
        </div>

        <p class="mt-5 text-xs text-white/50 px-4 leading-relaxed">
          Free to start &nbsp;&middot;&nbsp; No credit card required &nbsp;&middot;&nbsp; Used by 2,400+ marketers
        </p>

        <!-- Social proof avatars -->
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-2 px-4">
          <div class="flex -space-x-2">
            {[1,2,3,4,5].map(i => (
              <div class="h-7 w-7 rounded-full border-2 border-background bg-gradient-to-br from-primary/60 to-primary/20" />
            ))}
          </div>
          <p class="text-xs text-white/60 text-center">
            Join <span class="font-semibold text-white/80">2,400+</span> creators already making videos
          </p>
        </div>
      </div>
    </section>

    <!-- ── Product Types ─────────────────────────────────────── -->
    <section class="py-20 bg-background/95">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Three Ways to Create</h2>
          <p class="mt-4 text-muted-foreground max-w-xl mx-auto">Each mode is optimized for a different content type. Pick the one that fits your project.</p>
        </div>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="rounded-2xl border border-border/50 bg-card/50 p-6 hover:border-primary/50 transition-colors">
            <div class="text-3xl mb-3">🎬</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Cinematic</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Story-driven videos with dynamic AI visuals, cinematic camera motion, and image-to-video. Perfect for documentaries, brand stories, and social content.</p>
          </div>
          <div class="rounded-2xl border border-border/50 bg-card/50 p-6 hover:border-primary/50 transition-colors">
            <div class="text-3xl mb-3">📄</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Explainer (Doc2Video)</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Turn documents, blog posts, or transcripts into professional explainer videos with AI narration and custom caption styles.</p>
          </div>
          <div class="rounded-2xl border border-border/50 bg-card/50 p-6 hover:border-primary/50 transition-colors">
            <div class="text-3xl mb-3">⚡</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Smart Flow</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Single-scene infographic videos with custom layouts, brand colors, and animated text. Great for social media and presentations.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features ─────────────────────────────────────────── -->
    <section id="features" class="py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Everything You Need</h2>
          <p class="mt-4 text-muted-foreground max-w-xl mx-auto">From script to finished video — every step handled by AI, every scene editable by you.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {features.map((f) => (
            <div class="rounded-2xl border border-border/50 bg-card/50 p-6 hover:border-primary/30 transition-colors">
              <div class="text-2xl mb-3">{f.icon}</div>
              <h3 class="font-semibold text-foreground mb-2">{f.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Pricing ───────────────────────────────────────────── -->
    <section id="pricing" class="py-20 bg-background/95">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground">Simple, Transparent Pricing</h2>
          <p class="mt-4 text-muted-foreground max-w-xl mx-auto">Start free. Upgrade when you're ready. No hidden fees.</p>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <!-- Free -->
          <div class="rounded-2xl border border-border/50 bg-card/50 p-6 flex flex-col">
            <div>
              <h3 class="font-semibold text-foreground text-lg">Free</h3>
              <div class="mt-3 flex items-end gap-1">
                <span class="text-4xl font-bold text-foreground">$0</span>
                <span class="text-muted-foreground pb-1">/month</span>
              </div>
              <p class="mt-2 text-sm text-muted-foreground">Perfect for trying out the platform</p>
            </div>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground flex-1">
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 150 one-time credits</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 720p video export</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> Landscape format</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 3 Smart Flow videos</li>
              <li class="flex items-center gap-2 opacity-40"><span>✗</span> Voice cloning</li>
            </ul>
            <a href="/auth" class="mt-6 block rounded-xl border border-border/50 px-4 py-2.5 text-center text-sm font-medium text-foreground hover:bg-muted/50 transition-colors">
              Get Started Free
            </a>
          </div>

          <!-- Creator -->
          <div class="rounded-2xl border border-primary/40 bg-primary/5 p-6 flex flex-col relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="rounded-full bg-primary px-3 py-1 text-xs font-semibold text-primary-foreground">Most Popular</span>
            </div>
            <div>
              <h3 class="font-semibold text-foreground text-lg">Creator</h3>
              <div class="mt-3 flex items-end gap-1">
                <span class="text-4xl font-bold text-foreground">$29</span>
                <span class="text-muted-foreground pb-1">/month</span>
              </div>
              <p class="mt-2 text-sm text-muted-foreground">For content creators and small teams</p>
            </div>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground flex-1">
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 500 credits/month</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 1080p video export</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> Portrait & landscape</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 1 voice clone</li>
              <li class="flex items-center gap-2"><span class="text-primary">✓</span> 20 Smart Flow videos</li>
            </ul>
            <a href="/auth" class="mt-6 block rounded-xl bg-primary px-4 py-2.5 text-center text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity">
              Start with Creator
            </a>
          </div>

          <!-- Studio -->
          <div class="rounded-2xl border border-gold/40 bg-gold/5 p-6 flex flex-col">
            <div>
              <h3 class="font-semibold text-foreground text-lg">Studio</h3>
              <div class="mt-3 flex items-end gap-1">
                <span class="text-4xl font-bold text-foreground">$79</span>
                <span class="text-muted-foreground pb-1">/month</span>
              </div>
              <p class="mt-2 text-sm text-muted-foreground">For professionals and agencies</p>
            </div>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground flex-1">
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> 2,500 credits/month</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> 4K video export</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> 5 voice clones</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> Brand kit</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> Priority rendering</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> Character consistency</li>
              <li class="flex items-center gap-2"><span class="text-gold">✓</span> Unlimited Smart Flow</li>
            </ul>
            <a href="/auth" class="mt-6 block rounded-xl border border-gold/50 px-4 py-2.5 text-center text-sm font-semibold text-foreground hover:bg-gold/10 transition-colors">
              Start with Studio
            </a>
          </div>
        </div>

        <p class="mt-8 text-center text-sm text-muted-foreground">
          All plans include a 7-day money-back guarantee. Annual billing saves 20%.
          <a href="/pricing" class="text-primary hover:underline ml-1">See full pricing details →</a>
        </p>
      </div>
    </section>

    <!-- ── Trust ─────────────────────────────────────────────── -->
    <section class="py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="grid sm:grid-cols-3 gap-8 text-center">
          <div>
            <div class="text-3xl mb-2">🔒</div>
            <h3 class="font-semibold text-foreground">Secure by Design</h3>
            <p class="mt-1 text-sm text-muted-foreground">Your data stays yours · Supabase-hosted infrastructure</p>
          </div>
          <div>
            <div class="text-3xl mb-2">👥</div>
            <h3 class="font-semibold text-foreground">Built for Creators</h3>
            <p class="mt-1 text-sm text-muted-foreground">From solo creators to teams — no video editing skills needed</p>
          </div>
          <div>
            <div class="text-3xl mb-2">🌍</div>
            <h3 class="font-semibold text-foreground">11 Languages</h3>
            <p class="mt-1 text-sm text-muted-foreground">Create videos in English, French, Spanish, and 8 more languages</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────── -->
    <section id="faq" class="py-20 bg-background/95">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-foreground">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="group rounded-xl border border-border/50 bg-card/50 open:border-primary/30 transition-colors">
              <summary class="flex cursor-pointer items-center justify-between px-5 py-4 font-medium text-foreground list-none">
                <span>{faq.q}</span>
                <svg class="h-4 w-4 text-muted-foreground transition-transform group-open:rotate-180 shrink-0 ml-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="px-5 pb-4 text-sm text-muted-foreground leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ──────────────────────────────────────────────── -->
    <section class="py-24">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground">
          Ready to Create Your First Video?
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Join thousands of creators turning text into professional videos with AI.
        </p>
        <a
          href="/auth"
          class="mt-8 inline-block rounded-xl bg-primary px-10 py-4 text-lg font-semibold text-primary-foreground hover:opacity-90 transition-opacity shadow-lg shadow-primary/25"
        >
          Start for Free — No Credit Card Required
        </a>
      </div>
    </section>
  </main>

  <!-- ── Footer ───────────────────────────────────────────── -->
  <footer class="relative z-10 border-t border-white/10 py-12 bg-background">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-10">
        <div class="col-span-2 sm:col-span-1">
          <a href="/" class="flex items-center gap-2">
            <img src="/momaxlogo.webp" alt="MotionMax" class="h-7 w-auto" />
          </a>
          <p class="mt-3 text-xs text-muted-foreground leading-relaxed">
            AI-powered video creation for creators and teams worldwide.
          </p>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-foreground mb-3">Product</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li><a href="#features" class="hover:text-foreground transition-colors">Features</a></li>
            <li><a href="#pricing" class="hover:text-foreground transition-colors">Pricing</a></li>
            <li><a href="/auth" class="hover:text-foreground transition-colors">Sign In</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-foreground mb-3">Legal</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li><a href="/terms" class="hover:text-foreground transition-colors">Terms of Service</a></li>
            <li><a href="/privacy" class="hover:text-foreground transition-colors">Privacy Policy</a></li>
            <li><a href="/acceptable-use" class="hover:text-foreground transition-colors">Acceptable Use</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-foreground mb-3">Support</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li><a href="mailto:support@motionmax.io" class="hover:text-foreground transition-colors">support@motionmax.io</a></li>
            <li><a href="https://twitter.com/motionmaxio" class="hover:text-foreground transition-colors" target="_blank" rel="noopener">Twitter / X</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted-foreground">
        <span>© 2026 MotionMax. All rights reserved.</span>
        <span>Made with AI · Powered by Claude, Hypereal, Seedance</span>
      </div>
    </div>
  </footer>

  <!-- Mobile menu toggle — minimal vanilla JS -->
  <script>
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconX = document.getElementById("icon-x");

    btn?.addEventListener("click", () => {
      const open = menu?.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
      iconMenu?.classList.toggle("hidden", open);
      iconX?.classList.toggle("hidden", !open);
    });

    // Close menu when clicking a link
    menu?.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn?.setAttribute("aria-expanded", "false");
        iconMenu?.classList.remove("hidden");
        iconX?.classList.add("hidden");
      });
    });
  </script>
<!-- Demo modal -->
<div id="demo-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
  <div id="demo-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  <div class="relative z-10 w-full max-w-3xl rounded-2xl overflow-hidden shadow-2xl border border-white/10">
    <button id="demo-close" class="absolute top-3 right-3 z-20 flex h-8 w-8 items-center justify-center rounded-full bg-black/60 text-white hover:bg-black/80 transition-colors" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <iframe
      id="demo-iframe"
      width="100%"
      height="450"
      src=""
      data-src="https://embed.app.guidde.com/playbooks/wvJwFaqbh66kuXS3hZ23ir?mode=videoOnly"
      title="Demonstrate Visual Content Creation With MotionMax"
      frameborder="0"
      referrerpolicy="unsafe-url"
      allowfullscreen="true"
      allow="clipboard-write"
      sandbox="allow-popups allow-popups-to-escape-sandbox allow-scripts allow-forms allow-same-origin allow-presentation"
      style="border-radius:0;display:block;"
    ></iframe>
  </div>
</div>

<script>
  const btn = document.getElementById("demo-btn");
  const modal = document.getElementById("demo-modal");
  const backdrop = document.getElementById("demo-backdrop");
  const closeBtn = document.getElementById("demo-close");
  const iframe = document.getElementById("demo-iframe") as HTMLIFrameElement;

  function openModal() {
    iframe.src = iframe.dataset.src!;
    modal!.classList.remove("hidden");
    modal!.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeModal() {
    modal!.classList.add("hidden");
    modal!.classList.remove("flex");
    iframe.src = "";
    document.body.style.overflow = "";
  }

  btn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });
</script>

