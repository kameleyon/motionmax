# IMPORTANT: Rotate SUPABASE_SERVICE_ROLE_KEY in Supabase dashboard immediately - this key was exposed in git history

# ============================================================
# MotionMax Worker Environment Variables
# Copy to .env and fill in values
# ============================================================

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Generation (REQUIRED)
# HYPEREAL_API_KEY: Hypereal account A — image generation, ASR (captions),
#   Lyria music, Hypereal-routed LLM (Gemini Flash). Stays on whatever
#   rate tier this account is on.
# HYPEREALIMAGE_API_KEY: Hypereal account B — VIDEO generation
#   (Seedance, Kling, Grok, Veo, Kling transitions) AND image-fallback
#   for gpt-image-2 when account A is throttled. Routed here as of
#   2026-05-14 because account B's dashboard rate for Seedance is
#   materially lower than account A's. If you only have one key, set
#   both env vars to the same value — video will work, just at the
#   higher rate.
# OPENROUTER_API_KEY: image fallback (openai/gpt-5.4-image-2) — fires
#   only when both Hypereal accounts are down. Pricier per image (~$0.22).
HYPEREAL_API_KEY=your-hypereal-account-a-key
HYPEREALIMAGE_API_KEY=your-hypereal-account-b-key
OPENROUTER_API_KEY=your-openrouter-key
REPLICATE_API_KEY=your-replicate-key
# ATLASCLOUD_API_KEY: PRIMARY cinematic video provider as of 2026-05-14.
# Routes to ByteDance Seedance 2.0 image-to-video. ~2× faster than
# Replicate (~1m40s vs ~3m35s), same model quality. Field-name footgun:
# AtlasCloud uses `last_image` (NOT `last_frame_image` like Replicate).
# Get key from https://www.atlascloud.ai/dashboard. Auth header uses
# `Bearer <key>` prefix even though their spec says raw apiKey.
ATLASCLOUD_API_KEY=your-atlascloud-key

# Text-to-Speech (REQUIRED - at least one)
ELEVENLABS_API_KEY=your-elevenlabs-key
FISH_AUDIO_API_KEY=your-fish-audio-key
LEMONFOX_API_KEY=your-lemonfox-key
GOOGLE_TTS_API_KEY=your-google-tts-key
# GOOGLE_TTS_API_KEY_2=your-google-tts-key-2
# GOOGLE_TTS_API_KEY_3=your-google-tts-key-3

# Worker Health (OPTIONAL)
# HEALTH_AUTH_TOKEN=your-secret-token
# PORT=10000

# Export Configuration (OPTIONAL - defaults shown)
# EXPORT_BATCH_SIZE=3
# EXPORT_SCENE_TIMEOUT_MS=300000
# EXPORT_KEN_BURNS=true
# EXPORT_CROSSFADE_DURATION=0.5
# EXPORT_AI_VIDEO=false
